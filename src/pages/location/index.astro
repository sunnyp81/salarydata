---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { formatGBP } from '../../lib/ukTaxCalc';

const locations = (await getCollection('locations')).sort((a, b) => b.data.locationMultiplier - a.data.locationMultiplier);
const regions = Array.from(new Set(locations.map((l) => l.data.region)));

const title = 'UK City Salary Directory — Pay, Cost of Living, Job Markets';
const description = `Browse salary, cost-of-living and job-market data for ${locations.length} UK cities. Compare pay multipliers, average rent and unemployment in one place.`;
---
<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Locations', url: '/location/' }]} />
    <h1>UK city salary directory</h1>
    <p class="lead">
      Salary, cost-of-living and job-market data for {locations.length} UK cities. Each city page
      lists median pay across 30 job titles, the local employer mix, average rent and how the area
      compares to neighbouring labour markets.
    </p>

    <h2>All cities, ranked by pay multiplier</h2>
    <p>
      Multiplier is the local median gross pay relative to the UK national median (UK = 1.00).
      Higher means a job pays more in nominal pounds than the UK average; cost of living usually
      eats some of that gap, so always compare both columns.
    </p>
    <table class="salary-table">
      <thead>
        <tr>
          <th>#</th><th>City</th><th>Region</th><th>Pay multiplier</th><th>Cost-of-living index</th><th>Avg rent (1-bed)</th><th>Unemployment</th>
        </tr>
      </thead>
      <tbody>
        {locations.map((l, i) => (
          <tr>
            <td>{i + 1}</td>
            <td><a href={`/location/${l.data.slug}/`}><strong>{l.data.name}</strong></a></td>
            <td>{l.data.region}</td>
            <td><strong>{l.data.locationMultiplier.toFixed(2)}×</strong></td>
            <td>{l.data.costOfLivingIndex}</td>
            <td>{formatGBP(l.data.averageRent1Bed)}</td>
            <td>{l.data.unemploymentRate}%</td>
          </tr>
        ))}
      </tbody>
    </table>

    <h2>Browse by region</h2>
    <div class="region-grid">
      {regions.map((region) => (
        <div class="region-block">
          <h3>{region}</h3>
          <ul>
            {locations.filter((l) => l.data.region === region).map((l) => (
              <li><a href={`/location/${l.data.slug}/`}>{l.data.name}</a> <span>· {l.data.locationMultiplier.toFixed(2)}×</span></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .lead { font-size: 1.05rem; color: var(--c-ink); max-width: 70ch; }
  .region-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; margin: 1rem 0 2rem; }
  .region-block {
    padding: 1rem 1.25rem; background: #f8fafc;
    border: 1px solid #e2e8f0; border-radius: 12px;
  }
  .region-block h3 { margin: 0 0 .5rem; font-size: 1rem; color: var(--c-ink); }
  .region-block ul { list-style: none; padding: 0; margin: 0; }
  .region-block li { padding: .25rem 0; font-size: .92rem; }
  .region-block li span { color: var(--c-muted); font-size: .85em; }
</style>
