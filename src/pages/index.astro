---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatGBP } from '../lib/ukTaxCalc';
import { buildWebsiteSchema, buildOrganizationSchema, buildEditorPersonSchema } from '../lib/schemaBuilder';
import { highestPayingCitiesFor } from '../lib/onsData';

const jobs = (await getCollection('jobs')).sort((a, b) => b.data.nationalMedianSalary - a.data.nationalMedianSalary);
const locations = (await getCollection('locations')).sort((a, b) => b.data.locationMultiplier - a.data.locationMultiplier);
const top10Jobs = jobs.slice(0, 10);
const top10Cities = locations.slice(0, 10);

// Reference job for "highest-paying cities for [job]" table — pick Software Engineer
const referenceJob = jobs.find((j) => j.data.slug === 'software-engineer')?.data ?? jobs[0].data;
const topCitiesForRef = highestPayingCitiesFor(referenceJob, await getCollection('locations'), 10);

const totalPageEstimate = jobs.length * locations.length;
const title = 'UK Salary Data — Average Pay, Take-Home Calculator & Job Market Intelligence';
const description = `UK salary data for ${jobs.length} job titles across ${locations.length} cities. Free 2024/25 take-home pay calculator. Source: ONS Annual Survey of Hours and Earnings.`;

const schema = [buildWebsiteSchema(), buildOrganizationSchema(), buildEditorPersonSchema()];
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="hero container">
    <p class="kicker">UK salary intelligence · ONS data · 2024/25 tax year</p>
    <h1>What does that <em>actually</em> pay in the UK?</h1>
    <p class="lead">
      The median UK full-time salary sits at <strong>£35,000</strong> — but the spread inside that figure is wide.
      We break it down role by role and city by city so you see the actual range for {jobs.length} jobs across {locations.length} UK cities, plus what the take-home looks like after income tax, NI, student loan and pension.
    </p>
    <div class="cta">
      <a href="/salary-calculator/" class="btn btn-amber">Calculate take-home pay</a>
      <a href="/salary/" class="btn btn-outline">Browse all salaries</a>
    </div>
    <ul class="hero-stats">
      <li><strong>{jobs.length}</strong><span>job titles</span></li>
      <li><strong>{locations.length}</strong><span>UK cities</span></li>
      <li><strong>{(jobs.length * locations.length).toLocaleString()}</strong><span>salary pages</span></li>
      <li><strong>2024/25</strong><span>tax year</span></li>
    </ul>
  </section>

  <section class="container">
    <h2>Highest-paying jobs in the UK</h2>
    <p>
      Ranked by national median gross pay. Figures are full-time annual base salary; bonuses, equity
      and overtime are excluded — total compensation in some of these roles can be 30–100% higher.
    </p>
    <table class="salary-table">
      <thead>
        <tr><th>#</th><th>Job</th><th>Category</th><th>Median</th><th>Upper quartile</th></tr>
      </thead>
      <tbody>
        {top10Jobs.map((j, i) => (
          <tr>
            <td>{i + 1}</td>
            <td><a href={`/salary/${j.data.slug}/`}><strong>{j.data.title}</strong></a></td>
            <td>{j.data.category}</td>
            <td><strong>{formatGBP(j.data.nationalMedianSalary)}</strong></td>
            <td>{formatGBP(j.data.nationalUpperQuartile)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="container">
    <h2>Highest-paying UK cities (across all roles)</h2>
    <p>
      Ranked by the regional pay multiplier applied to UK national medians. Higher multipliers mean
      the same job pays more in nominal pounds — though cost of living often eats some or all of the
      premium. Click into a city to see how its cost-of-living index compares.
    </p>
    <table class="salary-table">
      <thead>
        <tr><th>#</th><th>City</th><th>Region</th><th>Pay multiplier</th><th>Cost-of-living index</th></tr>
      </thead>
      <tbody>
        {top10Cities.map((l, i) => (
          <tr>
            <td>{i + 1}</td>
            <td><a href={`/location/${l.data.slug}/`}><strong>{l.data.name}</strong></a></td>
            <td>{l.data.region}</td>
            <td><strong>{l.data.locationMultiplier.toFixed(2)}×</strong></td>
            <td>{l.data.costOfLivingIndex}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="container">
    <h2>Where {referenceJob.title.toLowerCase()}s earn the most in the UK</h2>
    <p>
      As an example of how the city × job tables work, here are the 10 best-paying UK cities for
      {referenceJob.title.toLowerCase()}s. The same comparison runs on every job hub page.
    </p>
    <table class="salary-table">
      <thead>
        <tr><th>#</th><th>City</th><th>Median {referenceJob.title.toLowerCase()} salary</th><th>vs UK avg</th></tr>
      </thead>
      <tbody>
        {topCitiesForRef.map((c, i) => (
          <tr>
            <td>{i + 1}</td>
            <td><a href={`/salary/${referenceJob.slug}/${c.slug}/`}><strong>{c.name}</strong></a> <span style="color:var(--c-muted)">· {c.region}</span></td>
            <td><strong>{formatGBP(c.median)}</strong></td>
            <td style={c.diff >= 0 ? 'color:#15803d' : 'color:#b91c1c'}>{c.diff >= 0 ? '+' : ''}{c.diff}%</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="container methodology">
    <h2>How we calculate these figures</h2>
    <p>
      Every salary figure starts from the Office for National Statistics Annual Survey of Hours and
      Earnings — the official UK earnings dataset, drawn from a 1% sample of HMRC PAYE records. We
      use the full-time employee distribution and publish lower quartile, median and upper quartile
      figures together so you see the full earnings spread, not a single point estimate.
    </p>
    <p>
      Regional pay is adjusted using ONS regional median gross pay tables — a separate dataset to
      ASHE that captures the local wage premium or discount versus the UK average. London sits at
      roughly 1.28× the UK median; Reading and Cambridge near 1.12–1.15×; Liverpool, Belfast and
      Newcastle below 0.95×. These are derived multipliers, not direct local samples for every
      job — the assumption being that a {referenceJob.title.toLowerCase()} in Manchester earns
      Manchester's wage discount applied to the national {referenceJob.title.toLowerCase()} median.
      It's a reasonable first approximation, particularly where local sample sizes are too thin
      to publish ASHE directly.
    </p>
    <p>
      Take-home calculations apply 2024/25 thresholds for England, Wales and Northern Ireland:
      personal allowance £12,570 (tapered above £100,000), basic rate 20% to £50,270, higher rate
      40% to £125,140, additional rate 45% above. National Insurance is 8% on £12,570–£50,270 and
      2% above. Student loans (plans 1, 2, 4, 5 and postgraduate) and pension contributions are
      handled in the calculator. Scottish income tax bands differ and are not currently applied.
    </p>
    <p>
      The site doesn't gate any data behind email signup. We monetise via affiliate links to Reed
      (job listings) and TopCV (CV review), which never affects which numbers are published.
      <a href="/methodology/">Full methodology page</a>.
    </p>
  </section>

  <section class="container">
    <h2>Browse all {jobs.length} jobs and {locations.length} cities</h2>
    <p>
      All {totalPageEstimate}+ job × city combinations are indexed and crawlable — pick a job
      to see pay across every UK city, or pick a city to see the full salary table for that location.
    </p>
    <div class="link-cols">
      <div>
        <h3>By job</h3>
        <ul>
          {jobs.map((j) => <li><a href={`/salary/${j.data.slug}/`}>{j.data.title}</a></li>)}
        </ul>
      </div>
      <div>
        <h3>By city</h3>
        <ul>
          {locations.map((l) => <li><a href={`/location/${l.data.slug}/`}>{l.data.name}</a></li>)}
        </ul>
      </div>
      <div>
        <h3>Tools</h3>
        <ul>
          <li><a href="/salary-calculator/">UK take-home pay calculator</a></li>
          <li><a href="/salary/">All salary pages</a></li>
          <li><a href="/location/">All city pages</a></li>
          <li><a href="/company/">Company salaries</a></li>
          <li><a href="/methodology/">Methodology</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 4rem 1.5rem 2.5rem; max-width: 920px; }
  .kicker {
    font-family: var(--font-body); font-size: .78rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .12em; color: var(--ink-3);
    margin: 0 0 1rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-variation-settings: 'opsz' 144;
    font-weight: 700; letter-spacing: -.035em;
    line-height: 1.05; margin: 0 0 1.25rem;
  }
  .hero h1 em {
    font-style: italic; font-weight: 500;
    background: linear-gradient(120deg, var(--highlight) 0%, #d97706 100%);
    -webkit-background-clip: text; background-clip: text;
    color: transparent;
  }
  .lead { font-size: 1.15rem; color: var(--ink-2); max-width: 60ch; margin: 0 0 1.75rem; }
  .lead strong { color: var(--ink-1); font-weight: 600; }
  .cta { display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: 2.25rem; }
  .hero-stats {
    list-style: none; padding: 1.5rem 0 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.25rem; border-top: 1px solid var(--rule);
  }
  .hero-stats li { display: flex; flex-direction: column; gap: .15rem; }
  .hero-stats strong {
    font-family: var(--font-display); font-variation-settings: 'opsz' 96;
    font-size: 1.65rem; font-weight: 700; color: var(--ink-1);
    font-variant-numeric: tabular-nums; letter-spacing: -.02em;
  }
  .hero-stats span {
    font-size: .8rem; color: var(--ink-3); font-weight: 500;
    text-transform: uppercase; letter-spacing: .05em;
  }
  .methodology { max-width: 780px; }
  .methodology p { color: var(--ink-2); }
  .link-cols {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem; margin: 1.5rem 0 2rem;
  }
  .link-cols h3 {
    font-family: var(--font-body);
    font-size: .75rem; color: var(--ink-3); font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em; margin: 0 0 .65rem;
  }
  .link-cols ul { list-style: none; padding: 0; margin: 0; }
  .link-cols li { padding: .25rem 0; }
  .link-cols li a { color: var(--ink-2); font-size: .9rem; border: 0; }
  .link-cols li a:hover { color: var(--ink-1); }
</style>
