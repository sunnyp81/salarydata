---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import FAQ from '../../../../components/FAQ.astro';
import CVBuilderCTA from '../../../../components/CVBuilderCTA.astro';
import SalaryRangeChart from '../../../../components/SalaryRangeChart.tsx';
import TakeHomeCalculator from '../../../../components/TakeHomeCalculator.tsx';
import JobListingsWidget from '../../../../components/JobListingsWidget.tsx';
import SalaryComparison from '../../../../components/SalaryComparison.tsx';
import {
  adjustSalaryForLocation,
  experienceBands,
  nearbyCities,
  sameCategoryJobsIn,
} from '../../../../lib/onsData';
import {
  moneyPageIntro,
  categoryHeading,
  categoryNarrative,
  transitionToExperience,
  transitionToCalculator,
  transitionToJobs,
  transitionToComparison,
  transitionToCategoryDeepdive,
  transitionToNearbyCities,
  transitionToSameCategoryJobs,
  transitionToFaq,
} from '../../../../lib/copywriting';
import { buildBreadcrumbSchema, buildFaqSchema, buildOccupationSchema } from '../../../../lib/schemaBuilder';
import { reedJobsLink } from '../../../../lib/affiliateLinks';
import { formatGBP } from '../../../../lib/ukTaxCalc';
import { readReedCache } from '../../../../lib/cache';
import { isMoneyPageIndexed } from '../../../../lib/publishConfig';

export async function getStaticPaths() {
  const jobs = await getCollection('jobs');
  const locations = await getCollection('locations');
  return jobs.flatMap((job) =>
    locations.map((location) => ({
      params: { job: job.data.slug, location: location.data.slug },
      props: { job: job.data, location: location.data },
    }))
  );
}

const { job, location } = Astro.props;
const adj = adjustSalaryForLocation(job, location);
const bands = experienceBands(job, location.locationMultiplier);

const allLocations = await getCollection('locations');
const allJobs = await getCollection('jobs');

// Lateral linking
const nearby = nearbyCities(allLocations, location, 4);
const sameCatJobs = sameCategoryJobsIn(allJobs, job, 4);

// 4 comparison cities for SalaryComparison — different from "nearby" so user gets two angles
const comparisonCities = allLocations
  .filter((l) => l.data.slug !== location.slug)
  .sort((a, b) => b.data.population - a.data.population)
  .slice(0, 4)
  .map((l) => ({
    label: l.data.name,
    salary: Math.round(job.nationalMedianSalary * l.data.locationMultiplier),
    url: `/salary/${job.slug}/${l.data.slug}/`,
  }));

const currentRow = { label: location.name, salary: adj.median, isCurrent: true };
const ukAverage = { label: 'UK average', salary: job.nationalMedianSalary };

const relatedJobEntries = await Promise.all(
  job.relatedJobs.slice(0, 4).map(async (slug) => {
    try { return await getEntry('jobs', slug); } catch { return undefined; }
  })
);
const relatedJobs = relatedJobEntries.filter((e): e is NonNullable<typeof e> => !!e).slice(0, 3);

const cachedListings = readReedCache(job.slug, location.slug) ?? [];
const reedUrl = reedJobsLink(job.slug, location.slug, `${job.slug}-${location.slug}`);

const colDiff = Math.round(((adj.costOfLivingAdjusted - job.nationalMedianSalary) / job.nationalMedianSalary) * 100);
const colDirection = colDiff >= 0 ? 'more' : 'less';

// SEO
const year = new Date().getFullYear();
const title = `${job.title} Salary in ${location.name} ${year} | Average Pay & Take-Home`;
const description = `${job.title} salary in ${location.name} averages ${formatGBP(adj.median)} (${formatGBP(adj.lowerQuartile)}–${formatGBP(adj.upperQuartile)} middle 50%). Take-home calculator, live jobs, regional comparison. Source: ONS ASHE.`;
const url = `/salary/${job.slug}/${location.slug}/`;
const noindex = !isMoneyPageIndexed(job.slug, location.slug);

// Generated narrative blocks
const intro = moneyPageIntro(job, location, adj);
const catH2 = categoryHeading(job, location);
const catBody = categoryNarrative(job, location, adj);

// FAQs — answers lead with the £ figure
const monthlyGross = Math.round(adj.median / 12);
const monthlyTakeHomeApprox = Math.round(monthlyGross * 0.72);
const faqs = [
  {
    question: `What is the average ${job.title} salary in ${location.name}?`,
    answer: `<p><strong>${formatGBP(adj.median)} per year</strong> is the median ${job.title} salary in ${location.name}, drawn from ONS Annual Survey of Hours and Earnings data adjusted for the regional pay differential. Lower quartile sits at ${formatGBP(adj.lowerQuartile)}; upper quartile at ${formatGBP(adj.upperQuartile)}.</p>`,
  },
  {
    question: `How much does a ${job.title} earn per month in ${location.name}?`,
    answer: `<p>About <strong>${formatGBP(monthlyGross)} gross</strong>, which works out at roughly <strong>${formatGBP(monthlyTakeHomeApprox)} take-home</strong> after income tax and National Insurance for the 2024/25 tax year (assuming no student loan and a 5% pension contribution). Use the calculator above for a number that matches your own circumstances.</p>`,
  },
  {
    question: `What is the starting salary for a ${job.title} in ${location.name}?`,
    answer: `<p>Entry-level ${job.title}s in ${location.name} typically start between <strong>${formatGBP(bands[0].min)} and ${formatGBP(bands[0].max)}</strong>. Pay then steps up at the 3-year and 6-year marks — mid-level practitioners earn ${formatGBP(bands[1].min)}–${formatGBP(bands[1].max)}, with senior roles reaching ${formatGBP(bands[2].min)}–${formatGBP(bands[2].max)}.</p>`,
  },
  {
    question: `Is ${location.name} a good place to work as a ${job.title}?`,
    answer: `<p><strong>${
      adj.multiplier >= 1.05 && location.unemploymentRate <= 5
        ? 'Yes — strong on both pay and labour-market tightness.'
        : adj.multiplier >= 1.0
          ? 'Generally yes, with caveats around cost of living.'
          : adj.multiplier >= 0.95
            ? 'It depends on what you weight more heavily — pay, cost of living or commute.'
            : 'Pay sits below the UK average, but lower cost of living often offsets the headline gap.'
    }</strong> ${location.name} pays ${adj.multiplier > 1 ? `${Math.round((adj.multiplier - 1) * 100)}% above` : adj.multiplier < 1 ? `${Math.round((1 - adj.multiplier) * 100)}% below` : 'in line with'} the UK ${job.title} median, with major local employers including ${location.majorEmployers.slice(0, 3).join(', ')}. Cost of living runs at ${location.costOfLivingIndex} on the UK-100 index, so ${formatGBP(adj.median)} here has the real purchasing power of ${formatGBP(adj.costOfLivingAdjusted)} at the national average. Unemployment of ${location.unemploymentRate}% gives a useful read on how tight the local labour market is — under 4% generally favours candidates on pay.</p>`,
  },
  {
    question: `What skills do ${job.title}s need to earn more?`,
    answer: `<p>Reaching the upper-quartile ${formatGBP(adj.upperQuartile)} band tends to come down to depth in <strong>${job.requiredSkills.slice(0, 3).join(', ')}</strong>, plus a track record that lets you credibly take on senior or lead-level scope. Career outlook for the role is <strong>${job.growthOutlook}</strong>, so the speciality areas worth doubling down on are ${job.requiredSkills.slice(3, 5).join(' and ') || job.requiredSkills[0]}.</p>`,
  },
];

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Salaries', url: '/salary/' },
  { name: job.title, url: `/salary/${job.slug}/` },
  { name: location.name, url },
];

const schema = [
  buildBreadcrumbSchema(crumbs),
  buildFaqSchema(faqs.map((f) => ({ question: f.question, answer: f.answer.replace(/<[^>]+>/g, '') }))),
  buildOccupationSchema({
    name: `${job.title} in ${location.name}`,
    description: `${job.title} salary and job-market data for ${location.name}, UK.`,
    occupationLocation: location.name,
    medianSalary: adj.median,
    lowerSalary: adj.lowerQuartile,
    upperSalary: adj.upperQuartile,
    skills: job.requiredSkills,
    url,
  }),
];
---
<BaseLayout title={title} description={description} canonical={new URL(url, Astro.site).toString()} schema={schema} noindex={noindex}>
  <div class="container">
    <Breadcrumbs items={crumbs} />

    <section class="hero">
      <p class="eyebrow">{job.category} · {location.region}</p>
      <h1>{job.title} salary in {location.name}, {year}</h1>

      <div class="salary-card">
        <div class="salary-card-grid">
          <div class="salary-figure">
            <span class="salary-label">Median annual salary</span>
            <span class="salary-value">{formatGBP(adj.median)}</span>
            <span class="salary-unit">based on ONS ASHE, {location.region} regional adjustment</span>
          </div>
          <dl class="salary-meta">
            <div>
              <dt>Lower quartile</dt>
              <dd>{formatGBP(adj.lowerQuartile)}</dd>
            </div>
            <div>
              <dt>Upper quartile</dt>
              <dd>{formatGBP(adj.upperQuartile)}</dd>
            </div>
            <div>
              <dt>vs UK median</dt>
              <dd class={adj.multiplier >= 1 ? 'pos' : 'neg'}>
                {adj.multiplier >= 1 ? '+' : ''}{Math.round((adj.multiplier - 1) * 100)}%
              </dd>
            </div>
            <div>
              <dt>Open jobs (est.)</dt>
              <dd>{adj.activeJobListingsEstimate.toLocaleString()}</dd>
            </div>
          </dl>
        </div>
      </div>

      <div class="intro" set:html={intro} />

      <p class="source">
        Source: <a href="https://www.ons.gov.uk/employmentandlabourmarket/peopleinwork/earningsandworkinghours/bulletins/annualsurveyofhoursandearnings/2023" rel="noopener" target="_blank">ONS Annual Survey of Hours and Earnings</a>, {year - 1}, adjusted for the {location.region} regional pay differential. Updated {job.lastUpdated}. <a href="/methodology/">Methodology</a>.
      </p>
    </section>

    <SalaryRangeChart
      client:load
      lowerQuartile={adj.lowerQuartile}
      median={adj.median}
      upperQuartile={adj.upperQuartile}
      minimum={adj.minimum}
      maximum={adj.maximum}
    />

    <h2>{job.title} salary by experience in {location.name}</h2>
    <p>{transitionToExperience(job, location)} The four bands below reflect what each tier typically commands in {location.name} — local figures, not UK averages, with each step usually triggered by a level change rather than an annual increment.</p>
    <table class="salary-table">
      <thead>
        <tr>
          <th>Experience level</th>
          <th>Salary range</th>
          <th>Median</th>
        </tr>
      </thead>
      <tbody>
        {bands.map((b) => (
          <tr>
            <td><strong>{b.level}</strong></td>
            <td>{formatGBP(b.min)} – {formatGBP(b.max)}</td>
            <td>{formatGBP(Math.round((b.min + b.max) / 2))}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="callout">
      <strong>Cost-of-living adjusted:</strong>
      A {formatGBP(adj.median)} {job.title} salary in {location.name} buys what
      <strong>{formatGBP(adj.costOfLivingAdjusted)}</strong> would buy at the UK average — that's
      {Math.abs(colDiff)}% {colDirection} real purchasing power than the national figure.
    </div>

    <p>{transitionToCalculator(job, location)}</p>

    <TakeHomeCalculator client:visible defaultSalary={adj.median} jobTitle={job.title} location={location.name} />

    <CVBuilderCTA jobTitle={job.title} campaign={`${job.slug}-${location.slug}`} />

    <p>{transitionToJobs(job, location)}</p>

    <JobListingsWidget
      client:visible
      listings={cachedListings.slice(0, 5)}
      jobTitle={job.title}
      location={location.name}
      estimateCount={adj.activeJobListingsEstimate}
      reedUrl={reedUrl}
    />

    <p>{transitionToComparison(job, location)}</p>

    <SalaryComparison
      client:visible
      title={`${job.title} pay: ${location.name} versus UK average`}
      rows={[currentRow, ukAverage]}
    />

    <SalaryComparison
      client:visible
      title={`${job.title} pay across other UK cities`}
      rows={[currentRow, ...comparisonCities]}
    />

    <h2>{catH2}</h2>
    <p>{transitionToCategoryDeepdive(job)}</p>
    <div set:html={catBody} />

    {nearby.length > 0 && (
      <>
        <h2>{job.title} salaries in cities near {location.name}</h2>
        <p>{transitionToNearbyCities(job, location)} The four comparisons below show how pay shifts within the same region — multipliers come from the ONS regional median pay differential, so the figures already account for the regional gap.</p>
        <ul class="related">
          {nearby.map((nb) => {
            const nbMedian = Math.round(job.nationalMedianSalary * nb.locationMultiplier);
            const diff = nbMedian - adj.median;
            const sign = diff > 0 ? '+' : '';
            return (
              <li>
                <a href={`/salary/${job.slug}/${nb.slug}/`}>
                  <strong>{job.title} in {nb.name}</strong>
                  <span>{formatGBP(nbMedian)} median <em>({sign}{formatGBP(diff)} vs {location.name})</em></span>
                </a>
              </li>
            );
          })}
        </ul>
      </>
    )}

    {sameCatJobs.length > 0 && (
      <>
        <h2>Other {job.category.toLowerCase()} jobs in {location.name}</h2>
        <p>{transitionToSameCategoryJobs(job)} Salaries for closely related {job.category.toLowerCase()} roles in {location.name} are below — useful when comparing routes into or out of the {job.title} track.</p>
        <ul class="related">
          {sameCatJobs.map((sj) => (
            <li>
              <a href={`/salary/${sj.slug}/${location.slug}/`}>
                <strong>{sj.title} in {location.name}</strong>
                <span>{formatGBP(Math.round(sj.nationalMedianSalary * location.locationMultiplier))} median</span>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    {relatedJobs.length > 0 && (
      <>
        <h2>Roles with overlapping skills</h2>
        <ul class="related">
          {relatedJobs.map((rj) => (
            <li>
              <a href={`/salary/${rj.data.slug}/${location.slug}/`}>
                <strong>{rj.data.title} in {location.name}</strong>
                <span>{formatGBP(Math.round(rj.data.nationalMedianSalary * location.locationMultiplier))} median</span>
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    <p>{transitionToFaq(job, location)}</p>

    <FAQ items={faqs} />

    <p class="source small">
      Salary base figures: ONS Annual Survey of Hours and Earnings ({year - 1}), with regional
      adjustment from ONS regional median gross pay tables. Live job counts (where shown):
      Reed Jobseeker API, refreshed daily. Take-home calculations apply 2024/25 UK tax-year
      thresholds for England, Wales and Northern Ireland.
    </p>
  </div>
</BaseLayout>

<style>
  .hero { padding: 1.5rem 0 1rem; }
  .eyebrow {
    font-family: var(--font-body); font-size: .78rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .1em; color: var(--ink-3);
    margin: 0 0 .5rem; padding: 0;
  }
  .intro { color: var(--ink-2); font-size: 1.05rem; max-width: 70ch; margin-top: 1.5rem; }
  .intro :global(p) { margin: 0 0 1rem; }

  /* Salary hero card — the £ figure is the product */
  .salary-card {
    background: var(--surface-1);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--ink-1);
    border-radius: var(--r-md);
    padding: 2rem 2.25rem;
    margin: 1.5rem 0;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  /* Subtle dot grid in the corner — gives the card "data instrument" feel */
  .salary-card::after {
    content: '';
    position: absolute; top: 0; right: 0; width: 200px; height: 100%;
    background-image: radial-gradient(circle, var(--rule) 1px, transparent 1px);
    background-size: 14px 14px;
    opacity: .35;
    mask-image: linear-gradient(to left, black, transparent);
    pointer-events: none;
  }
  .salary-card-grid {
    display: grid; grid-template-columns: 1fr 1.1fr; gap: 2.5rem;
    align-items: center; position: relative; z-index: 1;
  }
  .salary-figure { display: flex; flex-direction: column; }
  .salary-label {
    font-family: var(--font-body);
    font-size: .78rem; color: var(--ink-3); font-weight: 600;
    text-transform: uppercase; letter-spacing: .1em;
    margin-bottom: .35rem;
  }
  .salary-value {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144;
    font-size: clamp(3rem, 7vw, 4.5rem);
    font-weight: 700;
    color: var(--ink-1);
    line-height: 1;
    letter-spacing: -.04em;
    font-variant-numeric: tabular-nums;
    margin: .15rem 0 .5rem;
  }
  .salary-unit { color: var(--ink-3); font-size: .88rem; }
  .salary-meta {
    margin: 0; padding: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem 2rem;
    border-left: 1px solid var(--rule); padding-left: 2.5rem;
  }
  .salary-meta > div { display: flex; flex-direction: column; }
  .salary-meta dt {
    font-family: var(--font-body);
    font-size: .72rem; color: var(--ink-3); font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em;
    margin-bottom: .35rem;
  }
  .salary-meta dd {
    margin: 0;
    font-family: var(--font-display); font-variation-settings: 'opsz' 96;
    font-size: 1.45rem; font-weight: 600; color: var(--ink-1);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.015em;
  }
  .salary-meta dd.pos { color: var(--positive); }
  .salary-meta dd.neg { color: var(--negative); }

  .source {
    color: var(--ink-3); font-size: .82rem;
    padding: .65rem 0; border-top: 1px solid var(--rule);
    margin-top: 1.25rem;
  }
  .source a { color: var(--ink-3); border-bottom: 1px solid var(--rule-strong); }
  .source a:hover { color: var(--accent); }
  .source.small { font-size: .78rem; margin-top: 2rem; }

  .callout {
    padding: 1.1rem 1.4rem;
    background: var(--positive-soft); border-left: 3px solid var(--positive);
    border-radius: 0 var(--r-sm) var(--r-sm) 0;
    margin: 1.5rem 0;
    color: var(--ink-1); font-size: .96rem;
  }

  /* Related-items grid — softer, more publication-like */
  .related {
    list-style: none; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: .65rem; margin: 0 0 2rem;
  }
  .related li a {
    display: flex; flex-direction: column; gap: .25rem;
    padding: 1rem 1.2rem;
    background: var(--surface-1); border: 1px solid var(--rule);
    border-radius: var(--r-md); color: var(--ink-1);
    border-bottom: 1px solid var(--rule);
    transition: border-color .15s ease, transform .15s ease;
  }
  .related li a:hover {
    border-color: var(--ink-2);
    transform: translateY(-1px);
    color: var(--ink-1);
  }
  .related li a strong {
    font-family: var(--font-display); font-weight: 600; font-size: 1.02rem;
    letter-spacing: -.01em;
  }
  .related li a span {
    color: var(--ink-3); font-size: .87rem;
    font-variant-numeric: tabular-nums;
  }
  .related li a em {
    font-style: normal; color: var(--ink-3); font-size: .85em;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 760px) {
    .salary-card { padding: 1.5rem; }
    .salary-card-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .salary-meta { border-left: 0; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  }
</style>
