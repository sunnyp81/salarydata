---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import FAQ from '../../../../components/FAQ.astro';
import SalaryRangeChart from '../../../../components/SalaryRangeChart.tsx';
import TakeHomeCalculator from '../../../../components/TakeHomeCalculator.tsx';
import CVBuilderCTA from '../../../../components/CVBuilderCTA.astro';
import { formatGBP } from '../../../../lib/ukTaxCalc';
import { buildBreadcrumbSchema, buildFaqSchema } from '../../../../lib/schemaBuilder';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((c) => ({ params: { company: c.data.slug }, props: { company: c.data } }));
}

const { company } = Astro.props;
const year = new Date().getFullYear();
const url = `/company/${company.slug}/salaries/`;
const title = `${company.name} Salaries ${year} | Average Pay by Role`;
const description = `${company.name} average salary is ${formatGBP(company.averageSalary)}. See pay by role — ${company.salaryByRole.map((r) => r.role).slice(0, 3).join(', ')} and more.`;

const topRole = [...company.salaryByRole].sort((a, b) => b.median - a.median)[0];

const faqs = [
  {
    question: `What is the average salary at ${company.name}?`,
    answer: `<p>The average salary at ${company.name} is <strong>${formatGBP(company.averageSalary)}</strong> per year across roughly ${company.employeeCount.toLocaleString()} employees.</p>`,
  },
  {
    question: `How much do ${topRole.role}s earn at ${company.name}?`,
    answer: `<p>${topRole.role}s at ${company.name} earn a median of <strong>${formatGBP(topRole.median)}</strong>, with a typical range of ${formatGBP(topRole.range[0])}–${formatGBP(topRole.range[1])}.</p>`,
  },
  {
    question: `Where is ${company.name} headquartered?`,
    answer: `<p>${company.name} is headquartered in ${company.headquarters} and is listed on the ${company.ftseIndex}.</p>`,
  },
];

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Companies', url: '/company/' },
  { name: company.name, url },
];

const schema = [
  buildBreadcrumbSchema(crumbs),
  buildFaqSchema(faqs.map((f) => ({ question: f.question, answer: f.answer.replace(/<[^>]+>/g, '') }))),
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <div class="container">
    <Breadcrumbs items={crumbs} />
    <h1>{company.name} Salaries ({year})</h1>
    <p>
      {company.name} ({company.ftseIndex}, {company.sector}) employs approximately
      <strong>{company.employeeCount.toLocaleString()}</strong> people, headquartered in {company.headquarters}.
      Average salary: <strong>{formatGBP(company.averageSalary)}</strong>.
    </p>

    <h2>Salary by role at {company.name}</h2>
    <table>
      <thead>
        <tr><th>Role</th><th>Median</th><th>Range</th></tr>
      </thead>
      <tbody>
        {company.salaryByRole.map((r) => (
          <tr>
            <td><strong>{r.role}</strong></td>
            <td>{formatGBP(r.median)}</td>
            <td>{formatGBP(r.range[0])} – {formatGBP(r.range[1])}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <SalaryRangeChart
      client:load
      lowerQuartile={topRole.range[0]}
      median={topRole.median}
      upperQuartile={topRole.range[1]}
      title={`${topRole.role} salary distribution at ${company.name}`}
    />

    <TakeHomeCalculator client:visible defaultSalary={company.averageSalary} jobTitle={`${company.name} employee`} />

    <CVBuilderCTA campaign={`company-${company.slug}`} />

    <FAQ items={faqs} />
  </div>
</BaseLayout>
