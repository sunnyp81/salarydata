---
export interface Props {
  items: { question: string; answer: string }[];
}
const { items } = Astro.props;
---
<section class="faq">
  <h2>Frequently asked questions</h2>
  {items.map((item) => (
    <details>
      <summary>{item.question}</summary>
      <div class="faq-answer" set:html={item.answer} />
    </details>
  ))}
</section>
<style>
  .faq { margin: 2rem 0; }
  .faq details {
    border-bottom: 1px solid var(--rule);
    padding: 1rem 0;
  }
  .faq summary {
    cursor: pointer;
    font-family: var(--font-display); font-variation-settings: 'opsz' 96;
    font-weight: 600; font-size: 1.08rem;
    color: var(--ink-1); letter-spacing: -.01em;
    list-style: none; padding-right: 2rem; position: relative;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after {
    content: '+'; position: absolute; right: 0; top: -2px;
    font-family: var(--font-body);
    font-size: 1.4rem; line-height: 1;
    color: var(--ink-3); font-weight: 300;
    transition: transform .2s ease, color .15s ease;
  }
  .faq details[open] summary::after { content: '+'; transform: rotate(45deg); color: var(--ink-1); }
  .faq summary:hover::after { color: var(--ink-1); }
  .faq-answer { margin-top: .85rem; color: var(--ink-2); line-height: 1.7; max-width: 70ch; }
  .faq-answer :global(p) { margin: 0 0 .75rem; }
  .faq-answer :global(strong) { color: var(--ink-1); font-weight: 600; }
</style>
