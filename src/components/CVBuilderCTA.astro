---
import { topCvLink } from '../lib/affiliateLinks';
export interface Props {
  jobTitle?: string;
  campaign?: string;
}
const { jobTitle, campaign } = Astro.props;
const ctx = jobTitle ? ` as a ${jobTitle}` : '';
const link = topCvLink(campaign);
---
<div class="cta-cv">
  <div>
    <h3>Earn more{ctx}</h3>
    <p>Get a free, expert CV review from TopCV — the UK's largest CV writing service. Applicants with a professionally written CV receive 2× more interview invitations.</p>
  </div>
  <a href={link} class="btn" rel="sponsored nofollow" target="_blank">Get free CV review →</a>
</div>
<style>
  .cta-cv {
    display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 1.5rem;
    background: var(--highlight-tint); border: 1px solid var(--highlight-soft);
    border-left: 3px solid var(--highlight);
    border-radius: 0 var(--r-md) var(--r-md) 0;
    padding: 1.4rem 1.6rem; margin: 2.5rem 0;
  }
  .cta-cv h3 {
    margin: 0 0 .4rem; font-size: 1.15rem;
    font-family: var(--font-display); font-weight: 600; letter-spacing: -.01em;
    color: var(--ink-1);
  }
  .cta-cv p { margin: 0; font-size: .94rem; color: var(--ink-2); max-width: 60ch; }
  .cta-cv .btn {
    background: var(--highlight); border-color: var(--highlight); color: #fff;
  }
  .cta-cv .btn:hover { background: #92400e; border-color: #92400e; color: #fff; }
  @media (max-width: 640px) {
    .cta-cv { grid-template-columns: 1fr; }
  }
</style>
