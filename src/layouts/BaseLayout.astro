---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
}

const { title, description, canonical, schema, ogImage = '/og-default.png' } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const schemaArray = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SalaryData" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    {schemaArray.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <strong>Salary</strong>Data<span>.co.uk</span>
        </a>
        <nav>
          <a href="/salary-calculator/">Calculator</a>
          <a href="/salary/">Salaries</a>
          <a href="/company/">Companies</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-cols">
          <div>
            <h4>Top jobs</h4>
            <ul>
              <li><a href="/salary/software-engineer/">Software Engineer</a></li>
              <li><a href="/salary/product-manager/">Product Manager</a></li>
              <li><a href="/salary/data-analyst/">Data Analyst</a></li>
              <li><a href="/salary/marketing-manager/">Marketing Manager</a></li>
              <li><a href="/salary/accountant/">Accountant</a></li>
              <li><a href="/salary/nurse/">Nurse</a></li>
              <li><a href="/salary/solicitor/">Solicitor</a></li>
              <li><a href="/salary/">All 30 jobs →</a></li>
            </ul>
          </div>
          <div>
            <h4>Top cities</h4>
            <ul>
              <li><a href="/location/london/">London</a></li>
              <li><a href="/location/manchester/">Manchester</a></li>
              <li><a href="/location/birmingham/">Birmingham</a></li>
              <li><a href="/location/edinburgh/">Edinburgh</a></li>
              <li><a href="/location/bristol/">Bristol</a></li>
              <li><a href="/location/leeds/">Leeds</a></li>
              <li><a href="/location/cambridge/">Cambridge</a></li>
              <li><a href="/location/">All 20 cities →</a></li>
            </ul>
          </div>
          <div>
            <h4>Tools</h4>
            <ul>
              <li><a href="/salary-calculator/">Take-home calculator</a></li>
              <li><a href="/company/">Company salaries</a></li>
              <li><a href="/methodology/">Methodology</a></li>
            </ul>
          </div>
          <div>
            <h4>About</h4>
            <ul>
              <li><a href="/about/">About SalaryData</a></li>
              <li><a href="/contact/">Contact</a></li>
              <li><a href="/privacy/">Privacy</a></li>
            </ul>
          </div>
        </div>
        <p class="footer-fineprint">
          <strong>SalaryData.co.uk</strong> — UK salary data drawn from the ONS Annual Survey of
          Hours and Earnings, with take-home pay calculations for tax year 2024/25 (England, Wales
          and Northern Ireland). Figures are guidance, not financial advice.
        </p>
      </div>
    </footer>
    <style is:global>
      :root {
        --c-bg: #ffffff;
        --c-ink: #0f172a;
        --c-muted: #475569;
        --c-faint: #e2e8f0;
        --c-accent: #0369a1;
        --c-accent-dark: #075985;
        --c-accent-soft: #e0f2fe;
        --c-positive: #15803d;
        --c-positive-soft: #dcfce7;
        --radius: 10px;
        --maxw: 1120px;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: var(--c-ink);
        background: var(--c-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .container { max-width: var(--maxw); margin: 0 auto; padding: 0 1.25rem; }
      h1, h2, h3, h4 { line-height: 1.25; color: var(--c-ink); font-weight: 700; }
      h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 .75rem; }
      h2 { font-size: clamp(1.3rem, 2.6vw, 1.7rem); margin: 2rem 0 .75rem; }
      h3 { font-size: 1.15rem; margin: 1.5rem 0 .5rem; }
      p { margin: 0 0 1rem; color: var(--c-ink); }
      a { color: var(--c-accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .site-header {
        background: #fff; border-bottom: 1px solid var(--c-faint);
        position: sticky; top: 0; z-index: 10;
      }
      .header-inner {
        display: flex; align-items: center; justify-content: space-between;
        padding: .75rem 1.25rem; gap: 1.5rem;
      }
      .logo { font-size: 1.15rem; color: var(--c-ink); font-weight: 500; }
      .logo strong { color: var(--c-accent); font-weight: 800; }
      .logo span { color: var(--c-muted); font-size: .85em; }
      .site-header nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      .site-header nav a { color: var(--c-ink); font-weight: 500; font-size: .95rem; }
      .site-footer {
        border-top: 1px solid var(--c-faint);
        padding: 2.5rem 0 3rem; margin-top: 4rem;
        background: #f8fafc; color: var(--c-muted);
        font-size: .9rem;
      }
      .footer-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
      .footer-cols h4 { font-size: .85rem; color: var(--c-ink); text-transform: uppercase; letter-spacing: .05em; margin: 0 0 .65rem; }
      .footer-cols ul { list-style: none; padding: 0; margin: 0; }
      .footer-cols li { padding: .2rem 0; }
      .footer-cols li a { color: var(--c-muted); font-size: .9rem; }
      .footer-cols li a:hover { color: var(--c-accent); }
      .footer-fineprint { padding-top: 1.5rem; border-top: 1px solid var(--c-faint); font-size: .85rem; }
      table { width: 100%; border-collapse: collapse; margin: 1rem 0 1.5rem; }
      th, td { padding: .65rem .85rem; text-align: left; border-bottom: 1px solid var(--c-faint); }
      th { background: #f8fafc; font-weight: 600; font-size: .9rem; color: var(--c-muted); }
      tbody tr:hover { background: #f8fafc; }
      code { background: #f1f5f9; padding: .1rem .35rem; border-radius: 4px; font-size: .9em; }
      .btn {
        display: inline-block; background: var(--c-accent); color: #fff;
        padding: .7rem 1.3rem; border-radius: var(--radius); font-weight: 600;
        border: none; cursor: pointer; font-size: .95rem;
      }
      .btn:hover { background: var(--c-accent-dark); text-decoration: none; }
      .btn-outline { background: transparent; color: var(--c-accent); border: 1.5px solid var(--c-accent); }
      .btn-outline:hover { background: var(--c-accent-soft); }
      .breadcrumbs { font-size: .88rem; color: var(--c-muted); margin: 1rem 0 0; }
      .breadcrumbs a { color: var(--c-muted); }
      .breadcrumbs span { margin: 0 .4rem; }
    </style>
  </body>
</html>
